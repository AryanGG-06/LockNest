<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LockNest - Login</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <!-- Login/Signup Section -->
    <div class="container" id="authSection">
        <div class="logo">
            <h1> 🔐LockNest</h1>
            <span>Secure · Fast · Reliable</span>
        </div>

        <!-- Tabs -->
        <div class="tabs">
            <button class="tab <%= typeof errorForm === 'undefined' || errorForm === 'login' ? 'active' : '' %>"  id="loginTab" onclick="switchTab('login')">Login</button>
            <button class="tab <%= typeof errorForm !== 'undefined' && errorForm === 'signup' ? 'active' : '' %>" id="signupTab" onclick="switchTab('signup')">Sign Up</button>
        </div>
        
        <!-- Login Form -->
        <form action="/auth/login" method="POST" id="loginForm" class="<%= typeof errorForm !== 'undefined' && errorForm === 'signup' ? 'hidden' : '' %>">
            <% if (typeof errorForm !== 'undefined' && errorForm === 'login') { %>
                <%- include('partials/errorMessage') %>
            <% } %>
            <div class="form-group">
                <label for="loginEmail">Email</label>
                <input type="email" name="email" id="loginEmail" placeholder="Enter your email" required>
            </div>
            <div class="form-group">
                <label for="loginPassword">Password</label>
                <input type="password" name="password" id="loginPassword" placeholder="Enter your password" required>
            </div>
            <button type="submit" class="btn btn-primary">Login</button>
            <p class="form-message">
                Don't have an account? <a href="#" onclick="event.preventDefault(); switchTab('signup')">Sign up</a>
            </p>
        </form>

        <!-- Signup Form -->
        <form action="/auth/signup" method="POST" id="signupForm" class="<%= typeof errorForm !== 'undefined' && errorForm === 'signup' ? '' : 'hidden' %>">
            <% if (typeof errorForm !== 'undefined' && errorForm === 'signup') { %>
                <%- include('partials/errorMessage') %>
            <% } %>
            <div class="form-group">
                <label for="signupName">Full Name</label>
                <input type="text" name="fullName" id="signupName" value ="<%= typeof oldInput !== 'undefined'? oldInput.fullName : '' %>" placeholder="Enter your full name" required>
            </div>
            <div class="form-group">
                <label for="signupEmail">Email</label>
                <input type="email" name="email" id="signupEmail" value ="<%= typeof oldInput !== 'undefined'? oldInput.email : '' %>" placeholder="Enter your email" required>
            </div>
            <div class="form-group">
                <label for="signupPassword">Password</label>
                <input type="password" name="password" id="signupPassword" value ="<%= typeof oldInput !== 'undefined'? oldInput.password : '' %>" placeholder="Create a password" required>
            </div>
            <div class="form-group">
                <label for="signupConfirm">Confirm Password</label>
                <input type="password" name="confirmPassword" id="signupConfirm" value ="<%= typeof oldInput !== 'undefined'? oldInput.confirmPassword : '' %>" placeholder="Confirm your password" required>
            </div>
            <button type="submit" class="btn btn-primary">Create Account</button>
            <p class="form-message">
                Already have an account? <a href="#" onclick="event.preventDefault(); switchTab('login')">Login</a>
            </p>
        </form>
    </div>

   

    <script>
        function switchTab(tab) {
            const loginForm = document.getElementById('loginForm');
            const signupForm = document.getElementById('signupForm');
            const loginTab = document.getElementById('loginTab');
            const signupTab = document.getElementById('signupTab');

            if (tab === 'login') {
                loginForm.classList.remove('hidden');
                signupForm.classList.add('hidden');
                loginTab.classList.add('active');
                signupTab.classList.remove('active');
            } else {
                signupForm.classList.remove('hidden');
                loginForm.classList.add('hidden');
                signupTab.classList.add('active');
                loginTab.classList.remove('active');
            }
        }

        
    </script> 
</body>
</html>